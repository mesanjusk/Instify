{
  "name": "instify-desktop",
  "version": "1.1.1",
  "description": "Instify — Institutions Simplified (Desktop)",
  "author": "Instify",
  "repository": {
    "type": "git",
    "url": "https://github.com/mesanjusk/Instify.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:frontend": "cd ../SocialFront && npm run build:desktop",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win --publish never"
  },
  "build": {
    "appId": "in.instify.desktop",
    "productName": "Instify",
    "copyright": "Copyright © 2025 Instify",
    "directories": {
      "output": "dist-electron",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "sync/**/*",
      "license/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/mongodb/",
        "to": "mongodb/",
        "filter": ["**/*"]
      },
      {
        "from": "resources/vc_redist.x64.exe",
        "to": "vc_redist.x64.exe"
      },
      {
        "from": "../SocialBackend/",
        "to": "backend/",
        "filter": ["**/*", "!.env", "!.git"]
      },
      {
        "from": "../SocialFront/dist/",
        "to": "frontend/",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Instify",
      "include": "scripts/installer.nsh"
    },
    "afterPack": "scripts/afterPack.js",
    "publish": [
      {
        "provider": "github",
        "owner": "mesanjusk",
        "repo": "Instify",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",
    "mongoose": "^7.6.1"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0"
  }
}
