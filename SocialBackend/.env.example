NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/<dbname>

# JWT
JWT_SECRET=<strong-random-secret>
ACCESS_TOKEN_SECRET=<strong-random-secret>
# Short-lived secret for password reset tokens (defaults to JWT_SECRET + '_reset' if unset)
RESET_TOKEN_SECRET=<strong-random-secret>

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# SMS/WhatsApp gateway API key (used for OTP delivery)
SMS_API_KEY=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# WhatsApp Cloud API (Meta)
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v18.0
WHATSAPP_TOKEN=
PHONE_NUMBER_ID=
VERIFY_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_ENFORCE_WEBHOOK_SIGNATURE=true
WHATSAPP_TOKEN_ENCRYPTION_KEY=
