NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/<dbname>

# JWT
JWT_SECRET=<strong-random-secret>
ACCESS_TOKEN_SECRET=<strong-random-secret>

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# WhatsApp Cloud API (Meta) — required for OTP delivery and welcome messages
# Get these from https://developers.facebook.com > Your App > WhatsApp > API Setup
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v19.0
WHATSAPP_TOKEN=<permanent-or-temp-access-token>
PHONE_NUMBER_ID=<whatsapp-phone-number-id>
VERIFY_TOKEN=<your-webhook-verify-token>
WHATSAPP_WEBHOOK_VERIFY_TOKEN=<your-webhook-verify-token>
WHATSAPP_ENFORCE_WEBHOOK_SIGNATURE=true
WHATSAPP_TOKEN_ENCRYPTION_KEY=
